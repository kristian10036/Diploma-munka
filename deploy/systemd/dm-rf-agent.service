[Unit]
Description=DM native RF agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rfagent
Group=rfagent
EnvironmentFile=/etc/dm/rf-agent.env
ExecStart=/opt/dm/bin/rf-agent
Restart=on-failure
RestartSec=3
TimeoutStopSec=20
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/srv/dm/recordings
RestrictSUIDSGID=true
LockPersonality=true
MemoryDenyWriteExecute=true
CapabilityBoundingSet=
AmbientCapabilities=

[Install]
WantedBy=multi-user.target
