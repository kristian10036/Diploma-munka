[Unit]
Description=SDRangel headless server
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=180
StartLimitBurst=5

[Service]
Type=simple
User=sdrangel
Group=sdrangel
EnvironmentFile=-/etc/diploma/sdrangel.env
ExecStart=/usr/local/bin/sdrangelsrv
Restart=on-failure
RestartSec=10s
TimeoutStopSec=20s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
PrivateDevices=false

[Install]
WantedBy=multi-user.target
