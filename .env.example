# Másold .env néven, majd változtasd meg a jelszavakat és a host útvonalakat.
COMPOSE_PROJECT_NAME=diploma_munka
HTTP_PORT=8080

# Alkalmazás és biztonság. Demo módban az auth kikapcsolható.
APP_MODE=demo
AUTH_MODE=disabled
AUTH_ANONYMOUS_READ=true
# Productionben SHA-256 hash kell; generálás: python3 python-processor/scripts/hash_api_token.py
AUTH_OPERATOR_TOKEN_SHA256=
AUTH_ADMIN_TOKEN_SHA256=
MAX_REQUEST_BYTES=209715200
LOG_FORMAT=json
LOG_LEVEL=INFO

# PostgreSQL / TimescaleDB
POSTGRES_DB=tscm_security
POSTGRES_USER=tscm_app
POSTGRES_PASSWORD=change_this_password
POSTGRES_DATA_PATH=postgres-data
UPLOADS_DATA_PATH=uploads-data

# Backend -> RF agent. Dockeres RF overlay esetén az rf-agent service neve használható.
RF_AGENT_INTEGRATION_ENABLED=true
RF_AGENT_URL=http://host.docker.internal:8765
RF_AGENT_WS_URL=ws://host.docker.internal:8765/ws/spectrum
RF_AGENT_TIMEOUT_SECONDS=3
SPECTRUM_SOURCE_MODE=spectrum_ingest
SPECTRUM_INGEST_WS_URL=ws://spectrum-ingest:8001/ws/spectrum
SPECTRUM_INGEST_TIMEOUT_SECONDS=5
RF_AGENT_HTTP_PORT=8765

# C++ RF agent – biztonságos alap: mock.
RF_SOURCE_MODE=auto
RF_SENSOR_ID=hp-demo-01
RF_SESSION_ID=hp-demo-session
RF_GAIN_DB=0
RF_MOCK_POINT_COUNT=2048
RF_MOCK_NOISE_FLOOR_DBM=-95
RF_MOCK_NOISE_DEVIATION_DB=2
RF_MOCK_RANDOM_SEED=23063
RF_REPLAY_DIRECTORY=
RF_REPLAY_LOOP=false
RF_REPLAY_SPEED=1
RECORDINGS_ROOT=./recordings
# Backend és RF agent közös recording-tárhelyvédelme.
RECORDINGS_MIN_FREE_BYTES=5368709120
RECORDINGS_MAX_BYTES=21474836480
RECORDINGS_MAX_DURATION_SECONDS=3600
RECORDINGS_RETENTION_DAYS=30

# FFT / kliens sebesség
FFT_SIZE=2048
FFT_WINDOW=hann
FFT_AVERAGING=4
FFT_MAX_FPS=10
FFT_CALIBRATION_OFFSET_DB=0
FFT_PEAK_THRESHOLD_DB=10
SPECTRUM_INGEST_MAX_QUEUE=32
SPECTRUM_INGEST_RECONNECT_SECONDS=2
SPECTRUM_CLIENT_MAX_FPS=5
SPECTRUM_INGEST_MAX_FRAME_BYTES=4194304

# Aaronia: a probe elérhető lehet anélkül, hogy a hardver source aktív lenne.
ENABLE_AARONIA=true
AARONIA_PROBE_EXECUTABLE=/usr/local/bin/aaronia-probe
AARONIA_PROBE_TIMEOUT_MS=5000
AARONIA_RTSA_LIBRARY_PATH=/opt/aaronia-rtsa-suite/Aaronia-RTSA-Suite-PRO/libAaroniaRTSAAPI.so
AARONIA_RBW_HZ=100000
AARONIA_REFERENCE_LEVEL_DBM=-20
AARONIA_MAX_SPECTRUM_POINTS=16384
AARONIA_OVERVIEW_TARGET_POINTS=512
AARONIA_MAX_FPS=10
AARONIA_RTSA_URL=http://host.docker.internal:54664
AARONIA_TIMEOUT_SECONDS=5

# UHD / USRP: csak natív, UHD-val fordított helper mellett kapcsold be.
ENABLE_USRP=true
USRP_PROBE_EXECUTABLE=/usr/local/bin/usrp-probe
USRP_PROBE_TIMEOUT_MS=5000
USRP_DEVICE_ARGS=
USRP_CENTER_FREQUENCY_HZ=100000000
USRP_SAMPLE_RATE_HZ=2000000
USRP_GAIN_DB=20
ENABLE_HACKRF=true
HACKRF_DEVICE_ARGS=
HACKRF_CENTER_FREQUENCY_HZ=100000000
HACKRF_SAMPLE_RATE_HZ=2000000
HACKRF_GAIN_DB=20
RF_HOTPLUG_POLL_MS=5000
SDR_DEVICE_GID=46

# SDRangel control plane. A data plane addig maradjon not_configured,
# amíg nincs valós, tesztelt IQ input/plugin.
SDRANGEL_ENABLED=false
SDRANGEL_API_URL=http://host.docker.internal:8091/sdrangel
SDRANGEL_TIMEOUT_SECONDS=5
SDRANGEL_DEVICE_SET_INDEX=0
SDRANGEL_DEVICE_SETTINGS_KEY=
SDRANGEL_DATA_PLANE_MODE=not_configured
SDRANGEL_DATA_PLANE_ENDPOINT=
SDRANGEL_IQ_SAMPLE_FORMAT=cf32_le
SDRANGEL_IQ_SAMPLE_RATE_HZ=0
SDRANGEL_IQ_QUEUE_SIZE=32
SDRANGEL_IQ_DROP_POLICY=drop_oldest

# Kismet – csak compose.rf.yaml mellett vagy külső Kismet esetén.
KISMET_INTEGRATION_ENABLED=false
KISMET_API_URL=http://host.docker.internal:2501
KISMET_API_KEY=
KISMET_HTTPD_USERNAME=kismet
KISMET_HTTPD_PASSWORD=change_me_kismet
KISMET_SERVER_NAME="Diploma Kismet"
KISMET_DEVICES_ENDPOINT=/devices/views/all/devices.json
KISMET_ALERTS_ENDPOINT=/alerts/all_alerts.json
KISMET_POLL_INTERVAL_SECONDS=15
KISMET_TIMEOUT_SECONDS=5
KISMET_HISTORY_RSSI_DELTA_DB=3
KISMET_HISTORY_HEARTBEAT_SECONDS=10
KISMET_SOURCE=hci0
KISMET_SOURCE_NAME=bluetooth0
KISMET_SOURCES=
KISMET_DATA_PATH=kismet-data
# Kismet Bluetooth/BLE adaptere – csak figyelmeztetéshez használja a backend
# (lásd BETTERCAP_BLE_INTERFACE), tartsd szinkronban a KISMET_SOURCE/
# KISMET_SOURCES értékével.
KISMET_BLUETOOTH_INTERFACE=hci0

# Bettercap BLE – külön konténer, opcionális profil mögött:
#   docker compose -f compose.yaml -f compose.rf.yaml -f compose.ai.yaml \
#     -f compose.bettercap.yaml --profile bettercap up -d --build
# Kismet marad az elsődleges Wi-Fi/Bluetooth adatforrás; a Bettercap csak BLE
# eszközfelderítésre és vendor-adat kiegészítésre szolgál. Bettercap nélkül
# (profil nélküli indításnál) ezek a beállítások hatástalanok.
BETTERCAP_INTEGRATION_ENABLED=false
BETTERCAP_API_URL=http://host.docker.internal:8081
BETTERCAP_USERNAME=user
BETTERCAP_PASSWORD=pass
BETTERCAP_API_TIMEOUT_SECONDS=5
BETTERCAP_BLE_ENABLED=true
# Lehetőleg külön adapter, mint a Kismet-é (KISMET_BLUETOOTH_INTERFACE).
BETTERCAP_BLE_INTERFACE=hci1
BETTERCAP_POLL_INTERVAL_SECONDS=2

# Wi-Fi/Bluetooth helyiség-referencia (baseline): mennyi ideig várjon a rendszer,
# mielőtt egy korábban mentett referencia-eszközt "hiányzó"-nak jelöl (csatorna-
# hopping / BLE advertising-intervallum miatti hamis hiányzás elkerülésére).
WIFI_BASELINE_MISSING_GRACE_SECONDS=180
BLUETOOTH_BASELINE_MISSING_GRACE_SECONDS=300

# Ollama + assistant + valódi RAG. Core módban maradhat kikapcsolva.
AI_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=300
ASSISTANT_MAX_CONTEXT_RECORDS=10
ASSISTANT_MAX_PROMPT_CHARS=12000
ASSISTANT_MAX_SOURCE_RECORDS=20
ASSISTANT_NUM_PREDICT=768
RAG_ENABLED=false
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=bge-m3
RAG_CHUNK_CHARACTERS=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# Online anomáliadetektálás
ANOMALY_QUEUE_SIZE=32
ANOMALY_HISTORY_FRAMES=24
ANOMALY_WARMUP_FRAMES=6
ANOMALY_PEAK_DELTA_DB=8
ANOMALY_MAD_MULTIPLIER=6
ANOMALY_NOISE_SHIFT_DB=5
ANOMALY_OCCUPANCY_CHANGE=0.12
ANOMALY_NARROWBAND_MAX_HZ=200000
ANOMALY_PERSISTENCE_FRAMES=3
ANOMALY_BANDWIDTH_RATIO_CHANGE=2.5
ANOMALY_COOLDOWN_FRAMES=10

# ML
ML_ENABLED=true
# rule | classical | cnn | onnx - only rule is wired to a real model today;
# classical/cnn/onnx report a clean not_trained/model_not_found status.
ML_MODEL_TYPE=rule
ML_DEVICE=cpu
ML_MODEL_ROOT=./ml/models
ML_DATA_ROOT=./ml/data

# Mentés/migráció
ALLOW_DESTRUCTIVE_MIGRATIONS=false
BACKUP_CONFIRMED=false
BACKUP_ROOT=./backups/runtime
EXPORT_ROOT=./exports
# Offline local monitoring (Grafana is intentionally not used)
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION=15d
# PROMETHEUS_DATA_PATH=/srv/dm/prometheus
