# HP laptop demo profile: no RF hardware is required.
RF_SOURCE_MODE=mock
RF_SENSOR_ID=hp-demo-01
RF_SESSION_ID=hp-demo-session
RF_MOCK_POINT_COUNT=2048
RF_MOCK_RANDOM_SEED=23063

ENABLE_AARONIA=true
AARONIA_AUTO_START=false
AARONIA_PROBE_ON_START=true
ENABLE_USRP=false
SDRANGEL_ENABLED=false

AI_ENABLED=false
RAG_ENABLED=false
ML_ENABLED=true
ML_DEVICE=cpu

FFT_SIZE=2048
FFT_WINDOW=hann
FFT_AVERAGING=4
FFT_MAX_FPS=5
SPECTRUM_CLIENT_MAX_FPS=5

RF_REPLAY_LOOP=false
RF_REPLAY_SPEED=1
RECORDINGS_ROOT=./recordings

# Native helper/control-plane defaults.
RF_AGENT_INTEGRATION_ENABLED=true
RF_AGENT_URL=http://rf-agent:8765
USRP_PROBE_EXECUTABLE=/usr/local/bin/usrp-probe
SDRANGEL_API_URL=http://host.docker.internal:8091
SDRANGEL_DATA_PLANE_MODE=not_configured
