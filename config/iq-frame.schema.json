{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diploma.local/schemas/iq-frame-v1.json",
  "title": "IqFrame v1 control/debug representation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "sensor_id", "source_type", "source_device", "session_id",
    "timestamp", "sequence", "center_frequency_hz", "sample_rate_hz", "samples",
    "metadata"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "sensor_id": {"type": "string", "minLength": 1},
    "source_type": {"enum": ["mock", "replay", "aaronia", "usrp", "hackrf"]},
    "source_device": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "sequence": {"type": "integer", "minimum": 0},
    "center_frequency_hz": {"type": "integer", "minimum": 1},
    "sample_rate_hz": {"type": "integer", "minimum": 1},
    "samples": {
      "description": "Debug JSON only; production IQ transport will be binary and optional.",
      "type": "array",
      "minItems": 1,
      "maxItems": 4194304,
      "items": {
        "type": "array",
        "prefixItems": [{"type": "number"}, {"type": "number"}],
        "items": false,
        "minItems": 2,
        "maxItems": 2
      }
    },
    "metadata": {
      "type": "object",
      "required": ["is_simulated"],
      "properties": {"is_simulated": {"type": "boolean"}},
      "additionalProperties": true
    }
  }
}
